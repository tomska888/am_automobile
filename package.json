{
    "name": "am-automobile",
    "version": "1.0.0",
    "private": true,
    "main": "server.js",
    "description": "AM Automobile — Vue 3 + Vite frontend, Node.js + Express + MySQL backend",
    "scripts": {
        "dev": "concurrently --kill-others-on-fail --names \"CLIENT,SERVER\" --prefix-colors \"cyan,yellow\" \"npm run dev --prefix client\" \"npm run dev --prefix server\"",
        "build": "npm install --prefix client && npm run build --prefix client",
        "start": "node server.js",
        "server:dev": "nodemon server/server.js",
        "lint": "eslint client --ext .vue,.js --fix"
    },
    "dependencies": {
        "@vitejs/plugin-vue": "^5.0.4",
        "axios": "^1.6.8",
        "bcryptjs": "^2.4.3",
        "cors": "^2.8.5",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "express-rate-limit": "^7.3.1",
        "express-session": "^1.18.0",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "morgan": "^1.10.0",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.9.8",
        "nodemailer": "^8.0.3",
        "pinia": "^2.1.7",
        "validator": "^13.12.0",
        "vite": "^5.2.0",
        "vue": "^3.4.21",
        "vue-i18n": "^9.10.2",
        "vue-router": "^4.3.0"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "nodemon": "^3.1.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=9.0.0"
    },
    "keywords": [
        "car-dealership",
        "vue",
        "vite",
        "express",
        "mysql"
    ],
    "author": "AM Automobile",
    "license": "UNLICENSED"
}