# ============================================================
#  AM Automobile – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# ─── Node Environment ─────────────────────────────────────────
# Options: development | production | test
NODE_ENV=development

# ─── Server ───────────────────────────────────────────────────
PORT=3000

# ─── MySQL Database ───────────────────────────────────────────
# Local development (XAMPP / local MySQL):
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=am_automobile

# Hostinger production example:
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=u123456789_am
# DB_PASSWORD=YourStrongPassword123!
# DB_NAME=u123456789_automobile

# ─── JWT Authentication ───────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# Development: http://localhost:5173
# Production: https://yourdomain.pl
CORS_ORIGIN=http://localhost:5173

# ─── Cloudinary (Required for photo uploads in admin panel) ───
# Create a free account at https://cloudinary.com
# Dashboard → API Keys → Copy Cloud Name, API Key, API Secret
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email / SMTP ─────────────────────────────────────────────
# Required for: password reset emails, contact form notifications.
# Leave commented out in development — Ethereal (fake SMTP) will
# be used automatically and preview URLs printed to the console.
#
# Hostinger SMTP example:
# MAIL_HOST=smtp.hostinger.com
# MAIL_PORT=587
# MAIL_USER=noreply@amautomobile.pl
# MAIL_PASS=YourEmailPassword
# MAIL_FROM=noreply@amautomobile.pl
# MAIL_TO=admin@amautomobile.pl

# ─── App URL ──────────────────────────────────────────────────
# Used to build the password-reset link included in emails.
# Development:  http://localhost:5173
# Production:   https://yourdomain.pl
APP_URL=http://localhost:5173
